# ─── Telegram bot configuration ───────────────────────────────────────
# Get token from @BotFather (https://t.me/BotFather) → /newbot → /token
BOT_TOKEN=1234567890:AAExampleToken_ReplaceWithYourBotFatherToken

# ─── Connection to the main site ──────────────────────────────────────
# Public URL of your site (must be reachable from the bot's server)
SITE_URL=https://rbx-store-production.up.railway.app

# Same value as the BOT_API_SECRET environment variable on the site
# (in Railway → Variables → BOT_API_SECRET).
# Both bot and site must have the SAME secret string.
SITE_API_SECRET=replace_with_long_random_string_min_32_chars

# ─── Optional ─────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs that get admin commands in the bot.
# Find your ID in @userinfobot. Example: 123456789,987654321
ADMIN_TG_IDS=

# Logging
LOG_LEVEL=INFO
